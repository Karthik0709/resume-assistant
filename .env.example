# Colab LLM Server (for inference)
COLAB_LLM_API_URL=http://localhost:5000

# Embedding Model
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Vector DB
VECTOR_DB_PATH=./data/vector_db
VECTOR_DB_COLLECTION=resume_chunks

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/chatbot.log

# Application
PROJECT_NAME=portfolio-chatbot
API_PORT=8000